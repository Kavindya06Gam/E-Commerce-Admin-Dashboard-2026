# =============================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file to Git
# =============================================

# --- Server ---
PORT=3000
NODE_ENV=production

# --- PostgreSQL (provided by Render) ---
DB_HOST=your_render_db_host
DB_PORT=5432
DB_NAME=your_render_db_name
DB_USER=your_render_db_user
DB_PASSWORD=your_render_db_password

# --- Secrets (minimum 32 characters each!) ---
JWT_SECRET=replace_with_a_very_long_random_string_32_chars_minimum
COOKIE_PASSWORD=replace_with_another_long_random_string_32_chars_minimum
SESSION_SECRET=replace_with_yet_another_long_random_string_32_chars_min
